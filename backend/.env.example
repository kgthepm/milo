# Backend Environment Configuration
# Copy this file to .env and customize for your setup.
# All values shown below are the defaults baked into the code —
# they only need to be set if you want to override them.

# Where the local Ollama service is reachable.
# OLLAMA_URL=http://localhost:11434

# Default model used for AI recommendations when the request omits one.
# Leave unset to require the user to pick a model from the UI dropdown.
# OLLAMA_MODEL=qwen3.5:2b

# Timeout (ms) for the AI generate call. Bump this on slower CPU systems
# where the model takes longer than 8 minutes to respond.
# OLLAMA_TIMEOUT_MS=480000

# Timeout (ms) for the GET /api/ollama/models request that lists installed models.
# OLLAMA_MODELS_TIMEOUT_MS=30000

# Timeout (ms) for the GET /api/ollama/status reachability check.
# OLLAMA_STATUS_TIMEOUT_MS=15000

# Backend HTTP port.
# PORT=3000
