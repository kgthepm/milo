# Environment Configuration Template
# Copy this file to .env and customize if needed for your setup

# Note: For local development, no environment variables are required.
# The Vite dev server proxies /api requests to the backend automatically.
# See vite.config.js for proxy configuration.

# Example configuration for network access (optional):
# Uncomment and modify if you need to connect to a backend on a different network
# VITE_API_BASE=http://YOUR_IP_ADDRESS:3000/api
